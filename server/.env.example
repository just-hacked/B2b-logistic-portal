PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Direct (non-pooler) connection used ONLY by `prisma migrate deploy` and
# introspection. Migrations need a direct connection because Prisma's advisory
# locks don't work through the transaction pooler (port 6543, pgbouncer=true).
# On Supabase, use the SAME credentials as DATABASE_URL but port 5432 and no
# pgbouncer params, e.g.:
#   postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
JWT_SECRET=replace_me
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me

# Use "production" on Render so secure, cross-site cookies are enabled.
NODE_ENV=production

# Public URL of the deployed frontend. Used to build the email verification
# link, so this MUST point at the live site (no localhost in production).
CLIENT_URL=https://elioswholesale.in
FRONTEND_URL=https://elioswholesale.in

# Email — production uses Brevo HTTP API (Render blocks outbound SMTP).
# Set BREVO_API_KEY and the app sends over HTTPS; the SMTP vars below are only
# used as a local-dev fallback when BREVO_API_KEY is empty.
# The EMAIL_FROM address MUST be a verified sender in your Brevo account.
BREVO_API_KEY=your_brevo_api_key
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Elios <your_gmail@gmail.com>

# Web Push (VAPID) — generate once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com

# Password reset — used to sign reset tokens (stored in password_resets table).
# Generate with: openssl rand -hex 32
RESET_PASSWORD_TOKEN_SECRET=replace_me
RESET_PASSWORD_EXPIRES_IN=15m

# Google OAuth — set both for Google Sign-In to work.
# FRONTEND also needs NEXT_PUBLIC_GOOGLE_CLIENT_ID on Vercel.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
